<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    controllerName="ai.dashboard.controller.Dashboard"
    displayBlock="true">

    <Page id="DashboardPage"
        showHeader="false"
        backgroundDesign="Solid"
        class="aiDashboardPage">

        <!-- Toolbar -->
        <customHeader>
            <OverflowToolbar>
                <Button
                    icon="sap-icon://nav-back"
                    press=".onNavBack"
                    tooltip="Back to Analysis"/>
                <Title text="{appState>/analysis/title}" level="H3" class="sapUiSmallMarginEnd"/>
                <ToolbarSeparator/>
                <Text text="{appState>/dataset/fileName}" class="sapUiSmallText sapUiSmallMarginEnd"/>
                <ObjectStatus
                    text="{appState>/analysis/confidenceScore}% Confidence"
                    state="{= parseInt(${appState>/analysis/confidenceScore}) >= 80 ? 'Success' : parseInt(${appState>/analysis/confidenceScore}) >= 60 ? 'Warning' : 'Error'}"/>
                <ToolbarSpacer/>
                <!-- Filter Bar -->
                <Select
                    id="quickFilterSelect"
                    width="160px"
                    change=".onQuickFilterChange"
                    class="sapUiSmallMarginEnd"
                    visible="{= ${appState>/analysis/filters/length} > 0 }"/>
                <Button
                    id="refreshBtn"
                    text="{i18n>refreshButton}"
                    icon="sap-icon://refresh"
                    press=".onRefresh"/>
                <Button
                    text="{i18n>exportButton}"
                    icon="sap-icon://excel-attachment"
                    press=".onExportDashboard"/>
                <Button
                    text="{i18n>downloadConfigButton}"
                    icon="sap-icon://download"
                    press=".onDownloadConfig"/>
                <Button
                    text="Analysis"
                    icon="sap-icon://artificial-intelligence"
                    press=".onNavToAnalysis"/>
            </OverflowToolbar>
        </customHeader>

        <content>
            <ScrollContainer height="100%" vertical="true" horizontal="false" width="100%">

                <!-- AI Notification Strip -->
                <MessageStrip
                    id="dashboardInfoStrip"
                    text="Dashboard generated by IBM watsonx AI — {appState>/analysis/kpis/length} KPIs, {appState>/analysis/charts/length} charts, {appState>/analysis/insights/length} insights"
                    type="Success"
                    showIcon="true"
                    showCloseButton="true"
                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"/>

                <!-- ── Dynamic Dashboard Container ───────────────── -->
                <VBox
                    id="dashboardContainer"
                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"
                    width="calc(100% - 2rem)">
                    <!-- Controls injected programmatically by DashboardBuilder -->
                </VBox>

                <!-- Empty State -->
                <VBox
                    id="emptyState"
                    visible="{= !${appState>/showDashboard} }"
                    alignItems="Center"
                    justifyContent="Center"
                    height="400px">
                    <core:Icon src="sap-icon://bar-chart" size="4rem" color="#94a3b8" class="sapUiSmallMarginBottom"/>
                    <Title text="No Dashboard Generated" level="H4" class="sapUiTinyMarginBottom"/>
                    <Text text="Please go back to the upload page and generate a dashboard first." class="sapUiSmallText"/>
                    <Button
                        text="Go to Upload"
                        type="Emphasized"
                        press=".onNavBack"
                        class="sapUiSmallMarginTop"/>
                </VBox>

                <!-- Bottom padding -->
                <VBox height="3rem"/>
            </ScrollContainer>
        </content>

        <dependents>
            <BusyDialog
                id="busyDialog"
                text="Rebuilding dashboard..."
                title="Please Wait"/>
        </dependents>
    </Page>
</mvc:View>
