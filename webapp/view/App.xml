<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    controllerName="ai.dashboard.controller.App"
    displayBlock="true">

    <f:ShellBar
        id="shellBar"
        title="{i18n>shellBarTitle}"
        secondTitle="{i18n>shellBarSubtitle}"
        homeIcon="sap-icon://bar-chart"
        showMenuButton="false"
        showNavButton="false"
        class="aiShellBar">

        <!-- Settings button -->
        <f:additionalContent>
            <OverflowToolbarButton
                icon="sap-icon://settings"
                text="Settings"
                tooltip="IBM watsonx Settings"
                press=".onOpenSettings"/>
        </f:additionalContent>
    </f:ShellBar>

    <!-- Main Navigation Container -->
    <NavContainer id="appNav" height="calc(100vh - 3.5rem)" />

</mvc:View>
